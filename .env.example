# NARE configuration
#
# Copy to `.env` and fill in the values you need. The CLI loads `.env`
# automatically through python-dotenv.

# --- LLM provider --------------------------------------------------------
# Set ONE of the following depending on which backend you want NARE to use.

# Option A: Gemini (recommended for getting started — free tier available).
#   Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default Gemini model.
# GEMINI_MODEL=gemini-2.0-flash

# Option B: Anthropic-compatible HTTP endpoint (real API or local proxy).
#   Standard endpoint: https://api.anthropic.com
#   Custom proxy:      http://localhost:20128/v1
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
