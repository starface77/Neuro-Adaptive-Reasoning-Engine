# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: API base URL (default: https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Model to use (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# For local proxy setup (alternative):
# ANTHROPIC_BASE_URL=http://localhost:20128/v1
# ANTHROPIC_API_KEY=your-proxy-token
# ANTHROPIC_MODEL=kr/claude-sonnet-4.5
